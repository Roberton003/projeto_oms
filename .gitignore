# --- Junk files (already in gitignore index) ---
linkedin_post.txt
simple_auth_manager_passwords.json.generated
populate_database.log
scripts/html_to_jpeg.py
diagram.html
pipeline_diagram.jpeg

# --- Regras Adicionadas ---

# Pasta para arquivos locais/ignorados
arquivos_ignorados/

# Ambiente virtual do Python
venv/

# Arquivos de cache e compilados do Python
__pycache__/
*.pyc

# Arquivos de log
*.log

# Arquivos de configuração e banco de dados do Airflow
airflow.cfg
airflow.db*

# Arquivos não versionados do Great Expectations
great_expectations/uncommitted/
gx/

# --- Dados brutos: versionar apenas fixtures pequenas ---
# Dados brutos não versionados (mantidos localmente para reprocessamento)
data/*.csv
data/*.json
data/*.parquet
# Mas preservar fixtures de teste pequenas
!tests/fixtures/

# --- dbt artifacts ---
dbt/target/
dbt/dbt_packages/
dbt/logs/
# profiles.yml versionado (portável com env vars)
# dbt/profiles.yml
# dbt generated user config
dbt/.user.yml

# --- DuckDB databases ---
*.duckdb
*.duckdb.wal

# --- Dados de ambiente ---
.env
.env.local

# --- Docker (artefatos gerados) ---
# Dockerfile is versioned (portável para CI/CD)
# !.github/

# --- Diretórios locais não versionados ---
database/
.serena/
oms_dw/
AGENTS.md

# --- Documentos de gestão interna (não fazem parte do código) ---
# docs/plans/ é versionado (planos de evolução, ADRs)
# Mas os documentos de sessão/prompt específicos não são:
docs/plans/PRD_profissionalizacao.md
docs/plans/PROMPT_EXECUCAO_OPENCODE.md
RELATORIO_EXECUCAO.md